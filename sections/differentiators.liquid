<section class="section aerys-features" aria-labelledby="features-title">
  <div class="container">
    <span class="sec-label">What Makes It Different</span>
    <h2 id="features-title" style="font-size:clamp(1.75rem,3.5vw,2.375rem);font-weight:800;line-height:1.2;margin-bottom:0">Built for skin. Built for sleep.</h2>

    <div class="aerys-features__grid">

      <article class="aerys-feat">
        <div class="aerys-feat__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="aerys-feat__title">Zero-Residue Technology™</h3>
        <p class="aerys-feat__desc">Our silicone micro-matrix releases cleanly from skin and hair — no adhesive transfer, no morning clean-up ritual.</p>
      </article>

      <article class="aerys-feat">
        <div class="aerys-feat__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3 class="aerys-feat__title">Beard-Friendly Formula</h3>
        <p class="aerys-feat__desc">Engineered for facial hair. The silicone matrix flexes around follicles and peels off cleanly — no tangles, no pain.</p>
      </article>

      <article class="aerys-feat">
        <div class="aerys-feat__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="aerys-feat__title">Skin-Safe Promise™</h3>
        <p class="aerys-feat__desc">Hypoallergenic, latex-free, fragrance-free. Third-party tested on all skin types including sensitive and reactive skin.</p>
      </article>

    </div>

    <div class="aerys-features__pills">
      <span class="aerys-pill">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        HSA / FSA Eligible
      </span>
      <span class="aerys-pill">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Skin-Safe Promise™
      </span>
      <span class="aerys-pill">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
        Engineered in the USA
      </span>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Differentiators", "settings": [] }
{% endschema %}
