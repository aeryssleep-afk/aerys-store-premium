<section class="aerys-hero" aria-labelledby="hero-headline">
  <div class="container">
    <p class="aerys-hero__tag">Clinical Sleep Optimization</p>
    <h1 id="hero-headline" class="aerys-hero__headline">
      AERYS™ is the 1-second nightly habit to fix it.
    </h1>
    <div class="aerys-hero__cta-row">
      <a href="#bundles" class="btn btn-light">START TONIGHT</a>
    </div>

    <div class="aerys-hero__problems">
      <div class="problem-card">
        <div class="problem-card__icon" aria-hidden="true">⏱</div>
        <div>
          <div class="problem-card__title">Chronic Fatigue</div>
          <div class="problem-card__desc">Reduced O₂ exchange disrupts cellular energy production overnight.</div>
        </div>
      </div>
      <div class="problem-card">
        <div class="problem-card__icon" aria-hidden="true">〰</div>
        <div>
          <div class="problem-card__title">Snoring &amp; Disrupted Sleep</div>
          <div class="problem-card__desc">Oral airway collapse is the primary driver of vibration, reducing REM depth.</div>
        </div>
      </div>
      <div class="problem-card">
        <div class="problem-card__icon" aria-hidden="true">◎</div>
        <div>
          <div class="problem-card__title">Jawline Structure Shift</div>
          <div class="problem-card__desc">Years of mouth breathing alter mandibular position and facial muscle tone.</div>
        </div>
      </div>
    </div>

    <div class="solution-card">
      <div class="solution-card__check" aria-hidden="true">✓</div>
      <div>
        <div class="solution-card__name">AERYS™ SleepPatch</div>
        <div class="solution-card__desc">Restores nasal airflow · Reduces jaw tension · 1-second to apply</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Hero", "settings": [] }
{% endschema %}
