<section class="section aerys-stats" aria-labelledby="stats-title">
  <div class="container">
    <span class="sec-label">Real Results</span>
    <h2 id="stats-title" style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:800;line-height:1.2">
      Data-backed.<br>Human-<span class="hi">validated.</span>
    </h2>

    <div class="aerys-stats__grid" role="list">
      <div class="aerys-stat-cell" role="listitem">
        <div class="aerys-stat-cell__number">94%</div>
        <div class="aerys-stat-cell__label">Reported better sleep quality within 14 days</div>
      </div>
      <div class="aerys-stat-cell" role="listitem">
        <div class="aerys-stat-cell__number">3.2×</div>
        <div class="aerys-stat-cell__label">Increased O₂ absorption vs. oral supplements</div>
      </div>
      <div class="aerys-stat-cell" role="listitem">
        <div class="aerys-stat-cell__number">68%</div>
        <div class="aerys-stat-cell__label">Average improvement in deep sleep duration</div>
      </div>
      <div class="aerys-stat-cell" role="listitem">
        <div class="aerys-stat-cell__number">12 hrs</div>
        <div class="aerys-stat-cell__label">Controlled sustained-release window</div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Stats", "settings": [] }
{% endschema %}
