<section class="section aerys-faq" id="faq" aria-labelledby="faq-title">
  <div class="container">
    <div class="aerys-faq__inner">

      <!-- Left col: label + headline + sub + button -->
      <div class="aerys-faq__left">
        <span class="sec-label">FAQ</span>
        <h2 id="faq-title" class="aerys-faq__headline">
          Questions we hear<br>
          <span class="hi">every night.</span>
        </h2>
        <p class="aerys-faq__sub">Sleep is personal. If your question isn&rsquo;t here, our team responds within a few hours.</p>
        <a href="/pages/contact" class="btn-outline">Contact Support</a>
      </div>

      <!-- Right col: accordion -->
      <div class="aerys-faq__list" role="list">

        <div class="aerys-faq__item" role="listitem">
          <button class="aerys-faq__trigger" aria-expanded="false" aria-controls="faq1">
            Is it safe to use every night?
            <span class="aerys-faq__plus" aria-hidden="true">+</span>
          </button>
          <div class="aerys-faq__answer" id="faq1" role="region">
            Yes. AERYS™ is formulated specifically for nightly, long-term use. Our pharma-grade silicone adhesive is hypoallergenic, latex-free, and dermatologically validated for continuous skin contact — safe for every skin type, including sensitive and reactive skin.
          </div>
        </div>

        <div class="aerys-faq__item" role="listitem">
          <button class="aerys-faq__trigger" aria-expanded="false" aria-controls="faq2">
            Will it irritate my skin?
            <span class="aerys-faq__plus" aria-hidden="true">+</span>
          </button>
          <div class="aerys-faq__answer" id="faq2" role="region">
            No. Our medical-grade silicone adhesive was specifically validated for dermal sensitivity. No acrylic, no latex, no harsh chemicals. Zero rash rate in third-party testing. If you experience any reaction within 30 nights, we refund in full — no questions asked.
          </div>
        </div>

        <div class="aerys-faq__item" role="listitem">
          <button class="aerys-faq__trigger" aria-expanded="false" aria-controls="faq3">
            How long until I see results?
            <span class="aerys-faq__plus" aria-hidden="true">+</span>
          </button>
          <div class="aerys-faq__answer" id="faq3" role="region">
            Most users report waking up more rested within 7–10 nights. Full benefits — reduced snoring, improved oxygen saturation, better jaw alignment — compound over 30–90 nights of consistent nasal breathing.
          </div>
        </div>

        <div class="aerys-faq__item" role="listitem">
          <button class="aerys-faq__trigger" aria-expanded="false" aria-controls="faq4">
            Where should I apply the patch?
            <span class="aerys-faq__plus" aria-hidden="true">+</span>
          </button>
          <div class="aerys-faq__answer" id="faq4" role="region">
            Center the strip over your lips, pressing gently to seal. Ensure lips are clean and dry before application. The breathability channel lets your lips open naturally if needed — your airway is never fully sealed.
          </div>
        </div>

        <div class="aerys-faq__item" role="listitem">
          <button class="aerys-faq__trigger" aria-expanded="false" aria-controls="faq5">
            Does it contain melatonin?
            <span class="aerys-faq__plus" aria-hidden="true">+</span>
          </button>
          <div class="aerys-faq__answer" id="faq5" role="region">
            No. AERYS™ contains zero active ingredients — no melatonin, no herbs, no supplements. It works purely by promoting nasal breathing, which naturally increases oxygen uptake and activates your body&rsquo;s own sleep mechanisms.
          </div>
        </div>

      </div><!-- /.aerys-faq__list -->
    </div><!-- /.aerys-faq__inner -->
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [],
  "presets": [{ "name": "FAQ" }]
}
{% endschema %}
