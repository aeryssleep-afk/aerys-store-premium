<section class="aerys-social" id="proof" aria-labelledby="social-title">
  <div class="container">
    <div class="aerys-social__rating">
      <span class="stars" aria-label="4.9 stars">★★★★★</span>
      <span class="aerys-social__rating-text">4.9 / 5 — from 2,847 verified buyers</span>
    </div>
    <h2 id="social-title" class="aerys-social__headline">
      Real people.<br><span class="hi">Real results.</span>
    </h2>

    <div class="aerys-carousel" aria-label="Customer video testimonials">
      <div class="aerys-carousel__track" id="carouselTrack">

        <div class="aerys-carousel__slide">
          <article class="aerys-vcard" onclick="aerysOpenModal(1)" role="button" tabindex="0" aria-label="Play James's testimonial">
            <div class="aerys-vcard__thumb">
              <img src="https://static.wixstatic.com/media/bba426_b91f0365b55e4afa8e9dc3fa51d3ddc4~mv2.png" alt="James R. testimonial" class="aerys-vcard__img lazy" width="360" height="640" loading="lazy">
              <div class="aerys-vcard__quote-overlay">"No more snoring — ever."</div>
              <div class="aerys-vcard__play" aria-hidden="true">
                <div class="aerys-vcard__play-btn"><svg class="aerys-vcard__play-icon" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
              </div>
            </div>
            <div class="aerys-vcard__footer">
              <div class="aerys-vcard__stars stars-sm" aria-label="5 stars">★★★★★</div>
              <p class="aerys-vcard__text">"Two weeks in and my wife is sleeping through the night. AERYS™ is the only thing that actually worked."</p>
              <div>
                <span class="aerys-vcard__author">James R.</span>
                <span style="font-size:.75rem;color:rgba(255,255,255,.4)"> · Austin, TX</span>
                <span class="aerys-vcard__verified">✓ Verified Buyer</span>
              </div>
            </div>
          </article>
        </div>

        <div class="aerys-carousel__slide">
          <article class="aerys-vcard" onclick="aerysOpenModal(2)" role="button" tabindex="0" aria-label="Play Robert's testimonial">
            <div class="aerys-vcard__thumb">
              <img src="https://static.wixstatic.com/media/bba426_0bc50a7ae9ec4b5b9ebd980ba0e4499b~mv2.png" alt="Robert D. testimonial" class="aerys-vcard__img lazy" width="360" height="640" loading="lazy">
              <div class="aerys-vcard__quote-overlay">"Best sleep of my life."</div>
              <div class="aerys-vcard__play" aria-hidden="true">
                <div class="aerys-vcard__play-btn"><svg class="aerys-vcard__play-icon" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
              </div>
            </div>
            <div class="aerys-vcard__footer">
              <div class="aerys-vcard__stars stars-sm" aria-label="5 stars">★★★★★</div>
              <p class="aerys-vcard__text">"I wake up rested for the first time in years. This tiny strip changed everything."</p>
              <div>
                <span class="aerys-vcard__author">Robert D.</span>
                <span style="font-size:.75rem;color:rgba(255,255,255,.4)"> · Portland, OR</span>
                <span class="aerys-vcard__verified">✓ Verified Buyer</span>
              </div>
            </div>
          </article>
        </div>

        <div class="aerys-carousel__slide">
          <article class="aerys-vcard" onclick="aerysOpenModal(3)" role="button" tabindex="0" aria-label="Play Ashley's testimonial">
            <div class="aerys-vcard__thumb">
              <img src="https://static.wixstatic.com/media/bba426_72c5273ffe78470f8e24e154f7e389f1~mv2.png" alt="Ashley K. testimonial" class="aerys-vcard__img lazy" width="360" height="640" loading="lazy">
              <div class="aerys-vcard__quote-overlay">"Finally found one that works."</div>
              <div class="aerys-vcard__play" aria-hidden="true">
                <div class="aerys-vcard__play-btn"><svg class="aerys-vcard__play-icon" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
              </div>
            </div>
            <div class="aerys-vcard__footer">
              <div class="aerys-vcard__stars stars-sm" aria-label="5 stars">★★★★★</div>
              <p class="aerys-vcard__text">"AERYS stays put all night but peels off gently in the morning. Best sleep in years."</p>
              <div>
                <span class="aerys-vcard__author">Ashley K.</span>
                <span style="font-size:.75rem;color:rgba(255,255,255,.4)"> · Denver, CO</span>
                <span class="aerys-vcard__verified">✓ Verified Buyer</span>
              </div>
            </div>
          </article>
        </div>

        <div class="aerys-carousel__slide">
          <article class="aerys-vcard" onclick="aerysOpenModal(4)" role="button" tabindex="0" aria-label="Play Dr. Kim's testimonial">
            <div class="aerys-vcard__thumb">
              <img src="https://static.wixstatic.com/media/bba426_5d81f635caae4a9fa130137e6b79e7ac~mv2.png" alt="Dr. Kim testimonial" class="aerys-vcard__img lazy" width="360" height="640" loading="lazy">
              <div class="aerys-vcard__quote-overlay">"I recommend it to patients."</div>
              <div class="aerys-vcard__play" aria-hidden="true">
                <div class="aerys-vcard__play-btn"><svg class="aerys-vcard__play-icon" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div>
              </div>
            </div>
            <div class="aerys-vcard__footer">
              <div class="aerys-vcard__stars stars-sm" aria-label="5 stars">★★★★★</div>
              <p class="aerys-vcard__text">"The adhesive spec sheet is the real thing. I recommend AERYS™ as a first intervention."</p>
              <div>
                <span class="aerys-vcard__author">Dr. R. Kim</span>
                <span style="font-size:.75rem;color:rgba(255,255,255,.4)"> · Chicago, IL</span>
                <span class="aerys-vcard__verified">✓ Verified Buyer</span>
              </div>
            </div>
          </article>
        </div>

      </div>
    </div>

    <p class="aerys-carousel__hint">Swipe to see more &rarr;</p>
    <div class="aerys-carousel__nav">
      <button class="aerys-carousel__btn" id="carouselPrev" aria-label="Previous">&#8592;</button>
      <div class="aerys-carousel__dots" id="carouselDots" role="tablist"></div>
      <button class="aerys-carousel__btn" id="carouselNext" aria-label="Next">&#8594;</button>
    </div>
  </div>
</section>

<div class="aerys-modal-overlay" id="aerysModalOverlay" role="dialog" aria-modal="true" aria-label="Video testimonial">
  <div class="aerys-modal">
    <button class="aerys-modal__close" id="aerysModalClose" aria-label="Close">✕</button>
    <div class="aerys-modal__video" id="aerysModalContent"></div>
  </div>
</div>

{% schema %}
{
  "name": "Social Proof Carousel",
  "settings": [],
  "presets": [{ "name": "Social Proof Carousel" }]
