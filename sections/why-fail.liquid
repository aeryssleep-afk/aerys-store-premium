<section class="section aerys-compare" aria-labelledby="compare-title">
  <div class="container">
    <div class="aerys-compare__inner">

      <div>
        <span class="sec-label">Why AERYS™ Is Different</span>
        <h2 id="compare-title" class="aerys-compare__headline">
          Stop waking up with<br>
          <span class="hi">skin rashes and black residue.</span>
        </h2>
        <p class="aerys-compare__body">
          While others use harsh industrial glue — the same stuff that rated 2.4★ on Trustpilot — we engineered a medical-grade silicone adhesive that lifts clean every single morning.
        </p>
      </div>

      <div>
        <div class="aerys-compare__table" role="table" aria-label="Adhesive comparison">
          <div class="aerys-compare__thead" role="row">
            <span></span>
            <span class="aerys-compare__thead-others">THE OTHERS</span>
            <span class="aerys-compare__thead-aerys">AERYS™</span>
          </div>
          <div class="aerys-compare__row" role="row">
            <span class="aerys-compare__attr">Adhesive Type</span>
            <span class="aerys-compare__bad"><span class="aerys-compare__x" aria-hidden="true">✗</span>Industrial<br>acrylic glue</span>
            <span class="aerys-compare__good"><span class="aerys-compare__check" aria-hidden="true">✓</span>Medical-Grade Silicone</span>
          </div>
          <div class="aerys-compare__row" role="row">
            <span class="aerys-compare__attr">Residue on Removal</span>
            <span class="aerys-compare__bad"><span class="aerys-compare__x" aria-hidden="true">✗</span>Black residue on skin</span>
            <span class="aerys-compare__good"><span class="aerys-compare__check" aria-hidden="true">✓</span>Zero residue. Clean lift.</span>
          </div>
          <div class="aerys-compare__row" role="row">
            <span class="aerys-compare__attr">Skin Rashes</span>
            <span class="aerys-compare__bad"><span class="aerys-compare__x" aria-hidden="true">✗</span>Common complaint (2.4★ avg)</span>
            <span class="aerys-compare__good"><span class="aerys-compare__check" aria-hidden="true">✓</span>Dermatologically tested · 0%</span>
          </div>
          <div class="aerys-compare__row" role="row">
            <span class="aerys-compare__attr">Beard Compatibility</span>
            <span class="aerys-compare__bad"><span class="aerys-compare__x" aria-hidden="true">✗</span>Pulls and destroys facial hair</span>
            <span class="aerys-compare__good"><span class="aerys-compare__check" aria-hidden="true">✓</span>Beard-friendly. Not beard-destroying.</span>
          </div>
          <div class="aerys-compare__row" role="row">
            <span class="aerys-compare__attr">Removal Pain</span>
            <span class="aerys-compare__bad"><span class="aerys-compare__x" aria-hidden="true">✗</span>Reported as painful</span>
            <span class="aerys-compare__good"><span class="aerys-compare__check" aria-hidden="true">✓</span>Gentle peel — no sting</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{ "name": "Why Fail", "settings": [] }
{% endschema %}
