<section class="section aerys-bundles" id="bundles" aria-labelledby="bundles-title">
  <div class="container">
    <span class="sec-label">AERYS™ — Choose Your Supply</span>
    <h2 id="bundles-title" class="aerys-bundles__headline">
      The longer you commit,<br>the <span class="hi">more you save.</span>
    </h2>
    <p class="aerys-bundles__sub">Every pack uses the same medical-grade formula. Pick the supply that matches your recovery goal.</p>

    <div class="aerys-bundles__grid">

      <!-- STARTER -->
      <article class="aerys-bundle">
        <div class="aerys-bundle__img-wrap">
          <img src="https://static.wixstatic.com/media/bba426_9447cd68d99d45829e71e80fd75a1565~mv2.png" alt="AERYS™ 30-Night Starter" class="aerys-bundle__img lazy" width="400" height="300" loading="lazy">
          <div class="aerys-bundle__img-dots"><span class="aerys-bundle__img-dot active"></span><span class="aerys-bundle__img-dot"></span></div>
          <p class="aerys-bundle__caption">Available for Him &amp; Her</p>
        </div>
        <div class="aerys-bundle__body">
          <span class="aerys-bundle__badge aerys-bundle__badge--starter">STARTER</span>
          <h3 class="aerys-bundle__name">30 Nights</h3>
          <p class="aerys-bundle__subtitle">AERYS™ Medical Tape · Starter</p>
          <ul class="aerys-bundle__features">
            <li>Medical-Grade Silicone adhesive</li>
            <li>Zero-Residue Technology™</li>
            <li>Beard-friendly formula</li>
          </ul>
          <div class="aerys-bundle__price-row">
            <span class="aerys-bundle__price">$29.99</span>
            <span class="aerys-bundle__price-count">/ 30 strips</span>
          </div>
          <p class="aerys-bundle__per-night">$1.00/night</p>
          <button class="aerys-bundle__cta aerys-bundle__cta--starter btn-full" onclick="aerysAddToCart('starter','The Assessment – 30 Nights',29.99)">Start Sleeping Better</button>
          <p class="aerys-bundle__cta-meta">HSA/FSA Eligible &nbsp;·&nbsp; Free US Shipping</p>
        </div>
      </article>

      <!-- MOST POPULAR -->
      <article class="aerys-bundle aerys-bundle--popular">
        <div style="background:#F59E0B;text-align:center;padding:.375rem;font-size:.6875rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#0A0A0A">
          ★ MOST POPULAR ★
        </div>
        <div class="aerys-bundle__img-wrap">
          <div style="text-align:right;margin-bottom:.5rem">
            <span style="background:rgba(67,97,238,.25);color:#8BA4FF;font-size:.6875rem;font-weight:700;padding:.25rem .625rem;border-radius:999px">E-Book Included</span>
          </div>
          <img src="https://static.wixstatic.com/media/bba426_9447cd68d99d45829e71e80fd75a1565~mv2.png" alt="AERYS™ 90-Night Protocol" class="aerys-bundle__img lazy" width="400" height="300" loading="lazy">
          <div class="aerys-bundle__img-dots"><span class="aerys-bundle__img-dot active"></span><span class="aerys-bundle__img-dot"></span></div>
          <p class="aerys-bundle__caption">Available for Him &amp; Her</p>
        </div>
        <div class="aerys-bundle__body">
          <span class="aerys-bundle__badge aerys-bundle__badge--popular">MOST POPULAR ⭐</span>
          <h3 class="aerys-bundle__name">90 Nights</h3>
          <p class="aerys-bundle__subtitle">AERYS™ Medical Tape · Best Seller</p>
          <ul class="aerys-bundle__features">
            <li>Medical-Grade Silicone adhesive</li>
            <li>Zero-Residue Technology™</li>
            <li>Beard-friendly formula</li>
            <li>90 nights — habit formation locked</li>
          </ul>
          <div class="aerys-bundle__price-row">
            <span class="aerys-bundle__price">$59.99</span>
            <span class="aerys-bundle__price-count">/ 90 strips</span>
            <span class="aerys-bundle__price-shipping">FREE SHIPPING</span>
          </div>
          <p class="aerys-bundle__per-night">$0.67/night</p>
          <button class="aerys-bundle__cta aerys-bundle__cta--popular btn-full" onclick="aerysAddToCart('protocol','The Protocol – 90 Nights',59.99)">Start Sleeping Better</button>
          <p class="aerys-bundle__cta-meta">HSA/FSA Eligible &nbsp;·&nbsp; Free US Shipping</p>
        </div>
      </article>

      <!-- MAXIMUM SAVINGS -->
      <article class="aerys-bundle aerys-bundle--savings">
        <div class="aerys-bundle__img-wrap">
          <img src="https://static.wixstatic.com/media/bba426_9447cd68d99d45829e71e80fd75a1565~mv2.png" alt="AERYS™ 180-Night Regimen" class="aerys-bundle__img lazy" width="400" height="300" loading="lazy">
          <div class="aerys-bundle__img-dots"><span class="aerys-bundle__img-dot active"></span><span class="aerys-bundle__img-dot"></span></div>
          <p class="aerys-bundle__caption">Available for Him &amp; Her</p>
        </div>
        <div class="aerys-bundle__body">
          <span class="aerys-bundle__badge aerys-bundle__badge--savings">MAXIMUM SAVINGS 🔥</span>
          <h3 class="aerys-bundle__name">180 Nights</h3>
          <p class="aerys-bundle__subtitle">AERYS™ Medical Tape · Performance</p>
          <ul class="aerys-bundle__features">
            <li>Medical-Grade Silicone adhesive</li>
            <li>Zero-Residue Technology™</li>
            <li>Beard-friendly formula</li>
            <li>180 nights — deep transformation</li>
            <li>Priority fulfillment + free shipping</li>
          </ul>
          <div class="aerys-bundle__price-row">
            <span class="aerys-bundle__price">$99.99</span>
            <span class="aerys-bundle__price-count" style="display:flex;flex-direction:column">/ 180 strips <span style="color:#4361EE;font-weight:700;font-size:.6875rem">Save $49.95 vs. Starter</span></span>
          </div>
          <p class="aerys-bundle__per-night">$0.55/night</p>
          <button class="aerys-bundle__cta aerys-bundle__cta--savings btn-full" onclick="aerysAddToCart('regimen','The Regimen – 180 Nights',99.99)">Start Sleeping Better</button>
          <p class="aerys-bundle__cta-meta">HSA/FSA Eligible &nbsp;·&nbsp; Free US Shipping</p>
        </div>
      </article>

    </div>

    <!-- TRUST ROW -->
    <div class="aerys-bundles__trust" role="list">
      <div class="aerys-bundles__trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        30-Night Money-Back Guarantee
      </div>
      <div class="aerys-bundles__trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        Skin-Safe Promise™
      </div>
      <div class="aerys-bundles__trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        No Subscriptions
      </div>
      <div class="aerys-bundles__trust-item" role="listitem">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
        Engineered in the USA
      </div>
    </div>

  </div>
</section>

