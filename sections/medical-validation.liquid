<section class="section aerys-medical" aria-labelledby="medical-title">
  <div class="container">
    <div class="aerys-medical__inner">

      <div>
        <div class="aerys-medical__video">
          <img
            src="https://static.wixstatic.com/media/bba426_9447cd68d99d45829e71e80fd75a1565~mv2.png"
            alt="Dr. Verified — Medical Professional endorsing AERYS™"
            class="aerys-medical__video-thumb lazy"
            width="600" height="375"
            fetchpriority="high"
          >
          <div class="aerys-medical__play" onclick="aerysPlayMedicalVideo()" role="button" tabindex="0" aria-label="Play medical validation video">
            <div class="aerys-medical__play-btn">
              <svg class="aerys-medical__play-icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="aerys-medical__dr-badge">
            <div class="aerys-medical__dr-icon" aria-hidden="true">👤</div>
            <div>
              <div class="aerys-medical__dr-name">Dr. Verified</div>
              <div class="aerys-medical__dr-title">Medical Professional</div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <span class="sec-label">Medical Validation</span>
        <h2 id="medical-title" class="aerys-medical__headline">
          Recommended by<br>
          <span class="hi">medical professionals.</span>
        </h2>
        <blockquote class="aerys-medical__quote">
          "Mouth breathing during sleep is one of the most underestimated contributors to poor recovery and facial structure changes. A simple nasal strip habit can make a measurable difference — and the quality of the adhesive matters enormously for patient compliance."
        </blockquote>
        <div class="aerys-medical__bullets">
          <div class="aerys-medical__bullet">
            <div class="aerys-medical__bullet-icon" aria-hidden="true">👤</div>
            <span><strong>Endorsed for nightly use</strong> — Safe for long-term, continuous application</span>
          </div>
          <div class="aerys-medical__bullet">
            <div class="aerys-medical__bullet-icon" aria-hidden="true">🏥</div>
            <span><strong>Medical-grade adhesive standard</strong> — Same class used in clinical wound dressings</span>
          </div>
          <div class="aerys-medical__bullet">
            <div class="aerys-medical__bullet-icon" aria-hidden="true">💳</div>
            <span><strong>HSA / FSA Eligible</strong> — Qualifies as a medical wellness expense</span>
          </div>
        </div>
        <a href="#bundles" class="btn btn-dark">GET MY 30-NIGHT TRIAL &rarr;</a>
      </div>

    </div>
  </div>
</section>

{% schema %}
{ "name": "Medical Validation", "settings": [] }
{% endschema %}
