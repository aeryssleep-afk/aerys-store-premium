<div class="aerys-overlay" id="aerysOverlay" role="presentation" aria-hidden="true"></div>
<aside class="aerys-cart" id="aerysCart" role="dialog" aria-modal="true" aria-label="Shopping cart">

  <div class="aerys-cart__header">
    <h2>Your Order</h2>
    <button class="aerys-cart__close" id="aerysCartClose" aria-label="Close cart">✕</button>
  </div>

  <!-- Free Shipping Banner — shown by JS when cart has items -->
  <div class="aerys-cart__shipping-banner" id="aerysShippingBanner" style="display:none" aria-live="polite">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v4h-7V8z"/><circle cx="5.5" cy="18.5" r="1.5"/><circle cx="18.5" cy="18.5" r="1.5"/></svg>
    FREE SHIPPING ACTIVATED!
  </div>

  <div class="aerys-cart__items" id="aerysCartItems" role="list">
    <div class="aerys-cart__empty" id="aerysCartEmpty">Your cart is empty.</div>
  </div>

  <div class="aerys-cart__footer" id="aerysCartFooter" style="display:none">

    <!-- Reservation Timer -->
    <div class="aerys-cart__timer" id="aerysCartTimer" aria-live="polite">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Your cart is reserved for <strong id="aerysTimerDisplay">10:00</strong>
    </div>

    <div class="aerys-cart__total">
      <span>Total</span>
      <span id="aerysCartTotal">$0.00</span>
    </div>

    <!-- Demand signal -->
    <p class="aerys-cart__demand">Selling fast this week</p>

    <!-- Upgraded CTA -->
    <button class="aerys-cart__checkout" id="aerysCheckoutBtn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      Proceed to Checkout
    </button>

    <!-- Trust badges -->
    <div class="aerys-cart__trust" role="list" aria-label="Trust indicators">
      <span class="aerys-cart__trust-pill" role="listitem">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Safe Checkout
      </span>
      <span class="aerys-cart__trust-pill" role="listitem">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 4v4h-7V8z"/><circle cx="5.5" cy="18.5" r="1.5"/><circle cx="18.5" cy="18.5" r="1.5"/></svg>
        Free Shipping
      </span>
      <span class="aerys-cart__trust-pill" role="listitem">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        30-Day Guarantee
      </span>
    </div>

  </div>
</aside>
{% schema %}
{ "name": "Cart Drawer", "settings": [] }
{% endschema %}
